# notarity staging API (server-side only — never exposed to the browser)
NOTARITY_API_BASE=https://staging-api.notarity.com
NOTARITY_FORM_SLUG=start-vienna-hackathon

# Basic Auth for the staging environment
NOTARITY_BASIC_USER=START
NOTARITY_BASIC_PASS=  # shared on Discord

# Submit in debug mode so no real booking/emails are created while developing.
# Set to "false" only for a clean, intentional live run.
NOTARITY_DEBUG=true

# LLM provider for document extraction (optional).
# Set ONE of the keys below; OpenAI takes precedence if both are set.
# If neither is set, the app falls back to a deterministic stub extractor (safe for demos).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
